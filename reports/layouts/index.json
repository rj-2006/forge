{{- $pages := where .Site.RegularPages "Type" "events" -}}
[
  {{- range $i, $p := $pages }}
  {{- if $i }},{{ end }}
  {
    "title": {{ $p.Title | jsonify }},
    "description": {{ $p.Params.description | jsonify }},
    "date": {{ $p.Date.Format "2006-01-02" | jsonify }},
    "slug": {{ $p.Params.slug | jsonify }},
    "url": {{ $p.Permalink | jsonify }}
  }
  {{- end }}
]
